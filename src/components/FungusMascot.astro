---
interface Props {
  label?: string;
}

const { label = 'Animated GS Developer mascot' } = Astro.props;
const mascotSrc = '/images/aboutme/gsdeveloper_3d_logo.png';
---

<figure class="fungus-mascot" aria-label={label} data-fungus-mascot data-src={mascotSrc}>
  <img class="fungus-fallback" src={mascotSrc} alt="" loading="eager" decoding="async" />
</figure>

<script>
  import * as THREE from 'three/src/Three.js';

  const initFungusMascots = () => {
    for (const container of document.querySelectorAll('[data-fungus-mascot]')) {
      if (!(container instanceof HTMLElement) || container.dataset.ready === 'true') continue;
      container.dataset.ready = 'true';

      const imageSrc = container.dataset.src;
      if (!imageSrc) continue;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
      const renderer = new THREE.WebGLRenderer({
        alpha: true,
        antialias: true,
        preserveDrawingBuffer: true,
      });
      const clock = new THREE.Clock();
      const resources: Array<THREE.BufferGeometry | THREE.Material> = [];
      let frame = 0;
      let points: THREE.Points | undefined;
      let material: THREE.ShaderMaterial | undefined;

      camera.position.set(0, 0, 6);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
      container.append(renderer.domElement);

      const resize = () => {
        const width = container.clientWidth || 1;
        const height = container.clientHeight || 1;
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
        renderer.setSize(width, height, false);
      };

      const makeParticleData = (image: HTMLImageElement) => {
        const sampleSize = 148;
        const canvas = document.createElement('canvas');
        canvas.width = sampleSize;
        canvas.height = sampleSize;
        const context = canvas.getContext('2d', { willReadFrequently: true });
        if (!context) return null;

        context.clearRect(0, 0, sampleSize, sampleSize);
        context.drawImage(image, 0, 0, sampleSize, sampleSize);
        const pixels = context.getImageData(0, 0, sampleSize, sampleSize).data;
        const targets: number[] = [];
        const scatters: number[] = [];
        const colors: number[] = [];
        const sizes: number[] = [];
        const step = 3;
        let minX = sampleSize;
        let maxX = 0;
        let minY = sampleSize;
        let maxY = 0;
        let weightedX = 0;
        let weightedY = 0;
        let totalWeight = 0;

        for (let y = 0; y < sampleSize; y += 1) {
          for (let x = 0; x < sampleSize; x += 1) {
            const alpha = pixels[(y * sampleSize + x) * 4 + 3];

            if (alpha < 42) continue;

            const weight = alpha / 255;
            weightedX += x * weight;
            weightedY += y * weight;
            totalWeight += weight;
            minX = Math.min(minX, x);
            maxX = Math.max(maxX, x);
            minY = Math.min(minY, y);
            maxY = Math.max(maxY, y);
          }
        }

        const hasVisiblePixels = minX <= maxX && minY <= maxY;
        const visibleCenterX =
          hasVisiblePixels && totalWeight > 0 ? weightedX / totalWeight : sampleSize / 2;
        const visibleCenterY =
          hasVisiblePixels && totalWeight > 0 ? weightedY / totalWeight : sampleSize / 2;
        const visibleSize = hasVisiblePixels ? Math.max(maxX - minX, maxY - minY, 1) : sampleSize;
        const scale = 3.08 / visibleSize;

        for (let y = 0; y < sampleSize; y += step) {
          for (let x = 0; x < sampleSize; x += step) {
            const offset = (y * sampleSize + x) * 4;
            const alpha = pixels[offset + 3];

            if (alpha < 42 || Math.random() < 0.08) continue;

            const red = pixels[offset] / 255;
            const green = pixels[offset + 1] / 255;
            const blue = pixels[offset + 2] / 255;
            const normalizedX = (x - visibleCenterX) * scale;
            const normalizedY = -(y - visibleCenterY) * scale;
            const radius = 1.95 + Math.random() * 2.85;
            const angle = Math.atan2(normalizedY, normalizedX) + (Math.random() - 0.5) * 2.6;

            targets.push(normalizedX, normalizedY, (Math.random() - 0.5) * 0.08);
            scatters.push(
              Math.cos(angle) * radius + (Math.random() - 0.5) * 1.4,
              Math.sin(angle) * radius + (Math.random() - 0.5) * 1.4,
              (Math.random() - 0.5) * 3.4,
            );
            colors.push(red, green, blue);
            sizes.push(16 + Math.random() * 14);
          }
        }

        return { targets, scatters, colors, sizes };
      };

      const createParticles = (image: HTMLImageElement) => {
        const data = makeParticleData(image);
        if (!data || data.targets.length === 0) return;

        const geometry = new THREE.BufferGeometry();
        geometry.setAttribute('targetPosition', new THREE.Float32BufferAttribute(data.targets, 3));
        geometry.setAttribute(
          'scatterPosition',
          new THREE.Float32BufferAttribute(data.scatters, 3),
        );
        geometry.setAttribute('particleColor', new THREE.Float32BufferAttribute(data.colors, 3));
        geometry.setAttribute('particleSize', new THREE.Float32BufferAttribute(data.sizes, 1));
        geometry.setAttribute('position', new THREE.Float32BufferAttribute(data.targets, 3));

        material = new THREE.ShaderMaterial({
          transparent: true,
          depthWrite: false,
          blending: THREE.AdditiveBlending,
          uniforms: {
            uProgress: { value: prefersReducedMotion ? 0 : 0.08 },
            uTime: { value: 0 },
            uPixelRatio: { value: Math.min(window.devicePixelRatio, 1.8) },
          },
          vertexShader: `
            attribute vec3 targetPosition;
            attribute vec3 scatterPosition;
            attribute vec3 particleColor;
            attribute float particleSize;
            uniform float uProgress;
            uniform float uTime;
            uniform float uPixelRatio;
            varying vec3 vColor;
            varying float vAlpha;

            void main() {
              float wave = sin((targetPosition.x * 2.2) + (targetPosition.y * 1.4) + (uTime * 2.4)) * 0.12;
              vec3 burst = scatterPosition + vec3(wave, -wave * 0.35, sin(uTime + scatterPosition.x) * 0.18);
              vec3 positionNow = mix(targetPosition, burst, uProgress);

              vColor = particleColor;
              vAlpha = 1.0 - (uProgress * 0.2);

              vec4 mvPosition = modelViewMatrix * vec4(positionNow, 1.0);
              gl_Position = projectionMatrix * mvPosition;
              gl_PointSize = particleSize * uPixelRatio * (0.72 / -mvPosition.z);
            }
          `,
          fragmentShader: `
            varying vec3 vColor;
            varying float vAlpha;

            void main() {
              vec2 center = gl_PointCoord - vec2(0.5);
              float circle = 1.0 - smoothstep(0.22, 0.5, length(center));
              gl_FragColor = vec4(vColor, circle * vAlpha);
            }
          `,
        });

        points = new THREE.Points(geometry, material);
        // Visual correction for the source logo's asymmetric shape inside the circular frame.
        points.position.set(-0.34, 0.12, 0);
        points.rotation.z = -0.08;
        scene.add(points);
        resources.push(geometry, material);
        container.dataset.webglReady = 'true';
      };

      const image = new Image();
      image.decoding = 'async';
      image.onload = () => createParticles(image);
      image.src = imageSrc;

      const pointer = { x: 0, y: 0 };
      const handlePointerMove = (event: PointerEvent) => {
        const bounds = container.getBoundingClientRect();
        pointer.x = ((event.clientX - bounds.left) / bounds.width - 0.5) * 0.34;
        pointer.y = ((event.clientY - bounds.top) / bounds.height - 0.5) * 0.28;
      };

      const render = () => {
        const elapsed = clock.getElapsedTime();
        const cycle = (Math.sin(elapsed * 1.15) + 1) / 2;
        const pulse = prefersReducedMotion ? 0 : Math.pow(cycle, 2.4) * 0.92;

        if (material) {
          material.uniforms.uTime.value = elapsed;
          material.uniforms.uProgress.value = pulse;
        }

        if (points) {
          points.rotation.y = Math.sin(elapsed * 0.52) * 0.12 + pointer.x * 0.55;
          points.rotation.x = Math.cos(elapsed * 0.42) * 0.08 - pointer.y * 0.55;
          points.rotation.z = -0.08 + Math.sin(elapsed * 0.36) * 0.045;
          points.scale.setScalar(0.84 + (1 - pulse) * 0.12);
        }

        renderer.render(scene, camera);
        frame = window.requestAnimationFrame(render);
      };

      const observer = new ResizeObserver(resize);
      observer.observe(container);
      window.addEventListener('pointermove', handlePointerMove);
      resize();
      render();

      document.addEventListener(
        'astro:before-swap',
        () => {
          window.cancelAnimationFrame(frame);
          observer.disconnect();
          window.removeEventListener('pointermove', handlePointerMove);
          for (const resource of resources) resource.dispose();
          renderer.dispose();
        },
        { once: true },
      );
    }
  };

  initFungusMascots();
  document.addEventListener('astro:page-load', initFungusMascots);
</script>

<style>
  .fungus-mascot {
    --mascot-size: clamp(112px, 14vw, 172px);

    position: relative;
    display: grid;
    flex: 0 0 var(--mascot-size);
    width: var(--mascot-size);
    min-width: var(--mascot-size);
    max-width: var(--mascot-size);
    height: var(--mascot-size);
    min-height: var(--mascot-size);
    max-height: var(--mascot-size);
    margin: 0;
    place-items: center;
    justify-self: end;
    overflow: hidden;
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 52%, rgba(125, 211, 252, 0.18), transparent 44%),
      radial-gradient(circle at 64% 28%, rgba(56, 189, 248, 0.14), transparent 26%);
    contain: strict;
    isolation: isolate;
    transform: translateZ(0);
  }

  .fungus-mascot::before,
  .fungus-mascot::after {
    position: absolute;
    content: '';
    pointer-events: none;
  }

  .fungus-mascot::before {
    inset: 8%;
    border: 1px solid color-mix(in srgb, var(--paper-accent) 28%, transparent);
    border-radius: 50%;
    opacity: 0.58;
    animation: fungus-orbit 5.2s linear infinite;
  }

  .fungus-mascot::after {
    right: 20%;
    bottom: 11%;
    width: 58%;
    height: 11%;
    border-radius: 999px;
    background: rgba(2, 6, 23, 0.2);
    filter: blur(9px);
    opacity: 0.46;
    animation: fungus-shadow 3.4s ease-in-out infinite;
  }

  .fungus-mascot canvas {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    pointer-events: none;
  }

  .fungus-fallback {
    position: absolute;
    z-index: 1;
    width: 112%;
    height: 112%;
    object-fit: contain;
    opacity: 1;
    transform: scale(1.12);
    transition: opacity 220ms ease;
  }

  .fungus-mascot[data-webgl-ready='true'] .fungus-fallback {
    opacity: 0;
  }

  @keyframes fungus-orbit {
    0% {
      transform: rotate(0deg) scale(0.94);
    }

    50% {
      transform: rotate(180deg) scale(1.05);
    }

    100% {
      transform: rotate(360deg) scale(0.94);
    }
  }

  @keyframes fungus-shadow {
    0%,
    100% {
      opacity: 0.46;
      transform: scaleX(1);
    }

    50% {
      opacity: 0.18;
      transform: scaleX(0.62);
    }
  }

  @media (max-width: 720px) {
    .fungus-mascot {
      --mascot-size: 104px;

      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fungus-mascot::before,
    .fungus-mascot::after {
      animation: none;
    }
  }
</style>
