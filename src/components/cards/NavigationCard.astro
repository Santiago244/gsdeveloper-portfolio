---
import Icon from '../Icon.astro';

interface NavItem {
  icon: string;
  title: string;
  subtitle: string;
  href: string;
}

const { items } = Astro.props as { items: NavItem[] };
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('#')) {
    return href;
  }

  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<article class="nav-card">
  <nav aria-label="identity websites">
    {
      items.map((item) => (
        <a class="nav-item" href={withBase(item.href)}>
          <span class="nav-icon">
            <Icon name={item.icon} />
          </span>
          <span>
            <strong>{item.title}</strong>
            <small>{item.subtitle}</small>
          </span>
          <Icon name="external" />
        </a>
      ))
    }
  </nav>
</article>

<style>
  .nav-card {
    width: 100%;
    padding: 0;
    border: 0;
    background: linear-gradient(135deg, var(--paper-card-wash-top), var(--paper-card-wash-bottom));
    box-shadow: none;
  }

  nav {
    display: grid;
    width: 100%;
    gap: 10px;
  }

  .nav-item {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr) 18px;
    gap: 12px;
    align-items: center;
    padding: 14px 14px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--paper-card-wash-top), var(--paper-card-wash-bottom));
    color: var(--paper-ink);
    text-decoration: none;
    border: 1px solid var(--paper-line);
    box-shadow: var(--paper-shadow);
    transition: border-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .nav-item:hover {
    background: linear-gradient(135deg, var(--paper-card-wash-top), var(--paper-card-wash-bottom));
    border-color: var(--paper-line-strong);
    color: var(--paper-accent);
    transform: translateY(-1px);
  }

  .nav-icon,
  .nav-item > svg {
    color: var(--paper-accent);
  }

  .nav-icon svg,
  .nav-item > svg {
    width: 21px;
    height: 21px;
  }

  strong,
  small {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  strong {
    font-family: var(--font-display);
    font-size: 0.96rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: none;
  }

  small {
    margin-top: 2px;
    color: var(--paper-ink-soft);
    font-size: 0.82rem;
  }

  @media (max-width: 820px) {
    .nav-card {
      padding: 0;
    }

    nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 4px;
    }

    .nav-item {
      width: 100%;
      grid-template-columns: 24px minmax(0, 1fr);
      gap: 10px;
      justify-content: start;
      min-width: 0;
      padding: 9px 0;
    }

    .nav-icon {
      display: grid;
      place-items: center;
    }

    strong {
      max-width: 100%;
      text-align: left;
    }

    small,
    .nav-item > svg {
      display: none;
    }
  }
</style>



