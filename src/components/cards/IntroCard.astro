---
interface Intro {
  title: string;
  name: string;
  body: string[];
}

interface Quote {
  text: string[];
}

const { intro, quote } = Astro.props as { intro: Intro; quote?: Quote };
---

<article class="glass-card intro-card">
  <div class="intro-copy">
    <p class="kicker">Portfolio / AI / Telecommunications</p>
    <h2>
      <span>{intro.name}</span>
      <strong>{intro.title}</strong>
    </h2>
    {
      quote && (
        <blockquote>
          <span>{quote.text.slice(0, 2).join(' ')}</span>
          <span>{quote.text.slice(2).join(' ')}</span>
        </blockquote>
      )
    }
    <div class="intro-body">
      {intro.body.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <div class="intro-actions" aria-label="Primary actions">
      <a class="primary-action" href="/projects">View Projects</a>
      <a class="secondary-action" href="mailto:santiagogonzalezcuellar@gmail.com?subject=Portfolio%20project">Start a Conversation</a>
    </div>
  </div>
</article>

<style>
  .intro-card {
    min-height: 420px;
    padding: clamp(28px, 5vw, 48px);
    overflow: hidden;
    border-color: var(--paper-line-strong);
  }

  .intro-card:hover {
    transform: translateY(-2px);
  }

  .intro-copy {
    position: relative;
    z-index: 1;
    display: flex;
    width: 100%;
    max-width: 760px;
    flex-direction: column;
    align-items: flex-start;
  }

  .kicker {
    margin: 0 0 18px;
    color: var(--paper-accent);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    line-height: 1.3;
    text-transform: none;
  }

  h2 {
    display: grid;
    gap: 6px;
    max-width: 16ch;
    margin: 0 0 24px;
    color: var(--paper-ink);
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8vw, 6.8rem);
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 0.92;
    text-transform: none;
  }

  h2 span {
    color: var(--paper-accent);
  }

  h2 strong {
    font: inherit;
    font-size: clamp(1.85rem, 4vw, 3.45rem);
    line-height: 1.08;
  }

  blockquote {
    max-width: 58ch;
    margin: 0 0 24px;
    padding: 0 0 0 18px;
    border-left: 2px solid var(--paper-accent);
    color: var(--paper-ink-soft);
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.35vw, 1.18rem);
    font-style: italic;
    line-height: 1.72;
    text-align: left;
  }

  blockquote span {
    display: inline;
  }

  .intro-body {
    display: grid;
    max-width: 68ch;
    gap: 10px;
  }

  p {
    width: 100%;
    margin: 0;
    color: var(--paper-ink-soft);
    font-size: 1rem;
    line-height: 1.85;
  }

  .intro-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .intro-actions a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 18px;
    border: 1px solid var(--paper-line-strong);
    border-radius: 8px;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: none;
  }

  .primary-action {
    background: var(--paper-ink);
    color: var(--paper-bg);
    box-shadow: none;
  }

  .secondary-action {
    background: var(--paper-control);
    color: var(--paper-ink);
  }

  @media (max-width: 640px) {
    .intro-card {
      min-height: auto;
      padding: 24px;
    }

    h2 {
      max-width: 100%;
      font-size: clamp(2.6rem, 15vw, 4rem);
    }

    h2 strong {
      font-size: clamp(1.55rem, 8vw, 2.35rem);
    }

    .intro-actions {
      width: 100%;
    }

    .intro-actions a {
      width: 100%;
      justify-content: center;
    }
  }
</style>

