---
import Icon from '../Icon.astro';

interface Profile {
  name: string;
  handle: string;
  role: string;
  company: string;
  location: string;
  email: string;
  website: string;
  meta: string;
  avatar: string;
}

const { profile } = Astro.props as { profile: Profile };
---

<article class="profile-card">
  <div class="avatar-wrap">
    {
      profile.avatar ? (
        <img
          src={profile.avatar}
          alt={`${profile.name} profile photo`}
          loading="eager"
          decoding="async"
        />
      ) : (
        <span aria-hidden="true">GS</span>
      )
    }
  </div>

  <div class="profile-heading">
    <p class="eyebrow">{profile.company}</p>
    <h1>{profile.name}</h1>
    <p>{profile.handle}</p>
    <span class="role-line">
      <Icon name="sparkle" />
      <span>{profile.role}</span>
    </span>
  </div>

  <dl class="profile-meta" aria-label="Profile details">
    <div>
      <dt>Location</dt>
      <dd>{profile.location}</dd>
    </div>
    <div>
      <dt>Focus</dt>
      <dd>{profile.meta}</dd>
    </div>
  </dl>
</article>

<style>
  .profile-card {
    display: grid;
    justify-items: end;
    width: 100%;
    min-height: 420px;
    padding: 20px 0;
    overflow: hidden;
    text-align: right;
  }

  .avatar-wrap {
    position: relative;
    display: grid;
    width: 176px;
    height: 176px;
    margin: 0 0 18px auto;
    place-items: center;
    border: 1px solid var(--paper-line-strong);
    border-radius: 8px;
    background: linear-gradient(180deg, var(--paper-surface), var(--paper-surface-muted));
    box-shadow: var(--paper-shadow-lift);
    overflow: hidden;
  }

  .avatar-wrap::after {
    position: absolute;
    inset: 12px;
    border: 1px solid var(--paper-line);
    border-radius: 6px;
    content: '';
  }

  .avatar-wrap img {
    inset: -34px;
    width: calc(100% + 68px);
    height: calc(100% + 68px);
    border-radius: 6px;
    object-fit: contain;
    transform: scale(1.12);
  }

  .avatar-wrap span {
    margin-left: auto;
    color: var(--paper-ink);
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 4.8rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
    text-transform: none;
  }

  .profile-heading .eyebrow {
    margin: 0 0 8px;
    color: var(--paper-accent);
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: none;
  }

  .profile-heading h1 {
    margin: 0;
    color: var(--paper-ink);
    font-size: 1.72rem;
    letter-spacing: 0.02em;
  }

  .profile-heading p:not(.eyebrow) {
    margin: 4px 0 14px;
    color: var(--paper-ink-soft);
    font-size: 0.94rem;
  }

  .profile-heading .role-line {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    justify-content: flex-end;
    color: var(--paper-ink);
    font-size: 0.82rem;
  }

  .profile-heading svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
    color: var(--paper-accent);
  }

  .profile-meta {
    display: grid;
    width: min(100%, 260px);
    gap: 10px;
    margin: 22px 0 0;
  }

  .profile-meta div {
    padding-top: 12px;
    border-top: 1px solid var(--paper-line);
  }

  .profile-meta dt {
    margin: 0 0 4px;
    color: var(--paper-accent);
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: none;
  }

  .profile-meta dd {
    margin: 0;
    color: var(--paper-ink-soft);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  @media (max-width: 820px) {
    .profile-card {
      justify-items: center;
      min-height: auto;
      padding: 4px 0 0;
      text-align: center;
    }

    .avatar-wrap {
      margin-right: auto;
      margin-left: auto;
    }

    .profile-heading .role-line {
      justify-content: center;
    }

    .profile-meta {
      text-align: center;
    }
  }
</style>
